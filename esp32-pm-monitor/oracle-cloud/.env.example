# Copy to .env and fill in your values before running setup.sh.
# setup.sh will write this file for you interactively.
# .env is listed in .gitignore — never commit it.

# Secret used by the ESP32 in the X-API-Key header
API_KEY=change-me-secret-key

# Dashboard HTTP Basic Auth credentials
DASH_USER=admin
DASH_PASS=change-me-password

# Maximum readings kept in SQLite (oldest are pruned automatically)
MAX_RECORDS=10000
